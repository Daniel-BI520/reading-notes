<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 850 480" font-family="Arial, sans-serif">
  <rect width="850" height="480" fill="#F8F9FA" rx="8"/>
  <text x="425" y="30" text-anchor="middle" font-size="18" font-weight="bold" fill="#1F4E79">图6 金融数据中心网络分区架构（典型设计）</text>

  <!-- 核心层 -->
  <rect x="300" y="50" width="250" height="45" rx="5" fill="#1F4E79"/>
  <text x="425" y="78" text-anchor="middle" font-size="14" font-weight="bold" fill="white">数据中心核心（独立部署）</text>

  <!-- 各分区 -->
  <!-- 主机区 -->
  <rect x="30" y="120" width="155" height="200" rx="5" fill="#E8F0FE" stroke="#1F4E79" stroke-width="1.5"/>
  <rect x="30" y="120" width="155" height="30" rx="5" fill="#1F4E79"/>
  <text x="107" y="140" text-anchor="middle" font-size="11" fill="white">主机区(FW)</text>
  <text x="107" y="165" text-anchor="middle" font-size="9" fill="#333">IBM大型机</text>
  <text x="107" y="182" text-anchor="middle" font-size="9" fill="#333">核心账务系统</text>
  <rect x="40" y="195" width="135" height="20" rx="3" fill="white" stroke="#5B8DB8"/>
  <text x="107" y="209" text-anchor="middle" font-size="8" fill="#555">防火墙边界</text>
  <rect x="40" y="222" width="135" height="20" rx="3" fill="white" stroke="#5B8DB8"/>
  <text x="107" y="236" text-anchor="middle" font-size="8" fill="#555">汇聚+接入架构</text>
  <rect x="40" y="249" width="135" height="20" rx="3" fill="white" stroke="#5B8DB8"/>
  <text x="107" y="263" text-anchor="middle" font-size="8" fill="#555">双活部署</text>

  <!-- 开放平台区 -->
  <rect x="195" y="120" width="155" height="200" rx="5" fill="#EBF5EB" stroke="#2E7D32" stroke-width="1.5"/>
  <rect x="195" y="120" width="155" height="30" rx="5" fill="#2E7D32"/>
  <text x="272" y="140" text-anchor="middle" font-size="11" fill="white">开放平台区</text>
  <text x="272" y="165" text-anchor="middle" font-size="9" fill="#333">x86服务器</text>
  <text x="272" y="182" text-anchor="middle" font-size="9" fill="#333">分布式应用</text>
  <rect x="205" y="195" width="135" height="20" rx="3" fill="white" stroke="#A5D6A7"/>
  <text x="272" y="209" text-anchor="middle" font-size="8" fill="#555">Spine-Leaf Fabric</text>
  <rect x="205" y="222" width="135" height="20" rx="3" fill="white" stroke="#A5D6A7"/>
  <text x="272" y="236" text-anchor="middle" font-size="8" fill="#555">VXLAN隔离</text>
  <rect x="205" y="249" width="135" height="20" rx="3" fill="white" stroke="#A5D6A7"/>
  <text x="272" y="263" text-anchor="middle" font-size="8" fill="#555">SDN自动化</text>

  <!-- 大数据区 -->
  <rect x="360" y="120" width="130" height="200" rx="5" fill="#FFF3E0" stroke="#D9822B" stroke-width="1.5"/>
  <rect x="360" y="120" width="130" height="30" rx="5" fill="#D9822B"/>
  <text x="425" y="140" text-anchor="middle" font-size="11" fill="white">大数据区</text>
  <text x="425" y="165" text-anchor="middle" font-size="9" fill="#333">Hadoop/Spark</text>
  <text x="425" y="182" text-anchor="middle" font-size="9" fill="#333">风控/反欺诈</text>
  <rect x="370" y="195" width="110" height="20" rx="3" fill="white" stroke="#FFE0B2"/>
  <text x="425" y="209" text-anchor="middle" font-size="8" fill="#555">高带宽接入</text>
  <rect x="370" y="222" width="110" height="20" rx="3" fill="white" stroke="#FFE0B2"/>
  <text x="425" y="236" text-anchor="middle" font-size="8" fill="#555">大缓存设计</text>
  <rect x="370" y="249" width="110" height="20" rx="3" fill="white" stroke="#FFE0B2"/>
  <text x="425" y="263" text-anchor="middle" font-size="8" fill="#555">独立Fabric</text>

  <!-- DMZ区 -->
  <rect x="500" y="120" width="130" height="200" rx="5" fill="#FFEBEE" stroke="#C62828" stroke-width="1.5"/>
  <rect x="500" y="120" width="130" height="30" rx="5" fill="#C62828"/>
  <text x="565" y="140" text-anchor="middle" font-size="11" fill="white">DMZ区</text>
  <text x="565" y="165" text-anchor="middle" font-size="9" fill="#333">网银/手机银行</text>
  <text x="565" y="182" text-anchor="middle" font-size="9" fill="#333">Web接入层</text>
  <rect x="510" y="195" width="110" height="20" rx="3" fill="white" stroke="#EF9A9A"/>
  <text x="565" y="209" text-anchor="middle" font-size="8" fill="#555">异构防火墙</text>
  <rect x="510" y="222" width="110" height="20" rx="3" fill="white" stroke="#EF9A9A"/>
  <text x="565" y="236" text-anchor="middle" font-size="8" fill="#555">Anti-DDoS</text>
  <rect x="510" y="249" width="110" height="20" rx="3" fill="white" stroke="#EF9A9A"/>
  <text x="565" y="263" text-anchor="middle" font-size="8" fill="#555">SSL卸载</text>

  <!-- 运维管理区 -->
  <rect x="640" y="120" width="130" height="200" rx="5" fill="#F3E5F5" stroke="#7B1FA2" stroke-width="1.5"/>
  <rect x="640" y="120" width="130" height="30" rx="5" fill="#7B1FA2"/>
  <text x="705" y="140" text-anchor="middle" font-size="11" fill="white">运维管理区</text>
  <text x="705" y="165" text-anchor="middle" font-size="9" fill="#333">SDN控制器</text>
  <text x="705" y="182" text-anchor="middle" font-size="9" fill="#333">监控/CMDB</text>
  <rect x="650" y="195" width="110" height="20" rx="3" fill="white" stroke="#CE93D8"/>
  <text x="705" y="209" text-anchor="middle" font-size="8" fill="#555">带外管理网络</text>
  <rect x="650" y="222" width="110" height="20" rx="3" fill="white" stroke="#CE93D8"/>
  <text x="705" y="236" text-anchor="middle" font-size="8" fill="#555">堡垒机</text>
  <rect x="650" y="249" width="110" height="20" rx="3" fill="white" stroke="#CE93D8"/>
  <text x="705" y="263" text-anchor="middle" font-size="8" fill="#555">日志审计</text>

  <!-- 各分区到核心连接线 -->
  <line x1="107" y1="120" x2="370" y2="95" stroke="#1F4E79" stroke-width="1.5"/>
  <line x1="272" y1="120" x2="390" y2="95" stroke="#2E7D32" stroke-width="1.5"/>
  <line x1="425" y1="120" x2="425" y2="95" stroke="#D9822B" stroke-width="1.5"/>
  <line x1="565" y1="120" x2="460" y2="95" stroke="#C62828" stroke-width="1.5"/>
  <line x1="705" y1="120" x2="480" y2="95" stroke="#7B1FA2" stroke-width="1.5"/>

  <!-- 底部Fabric层 -->
  <rect x="30" y="340" width="740" height="60" rx="5" fill="#6B7280" opacity="0.3"/>
  <text x="400" y="365" text-anchor="middle" font-size="13" font-weight="bold" fill="#1F4E79">统一Fabric底座（Spine-Leaf + VXLAN + EVPN）</text>
  <text x="400" y="385" text-anchor="middle" font-size="10" fill="#555">每个分区独立Fabric或共享Fabric | ECMP多路径 | M-LAG高可用</text>
  <line x1="107" y1="320" x2="107" y2="340" stroke="#888" stroke-width="1" stroke-dasharray="3,3"/>
  <line x1="272" y1="320" x2="272" y2="340" stroke="#888" stroke-width="1" stroke-dasharray="3,3"/>
  <line x1="425" y1="320" x2="425" y2="340" stroke="#888" stroke-width="1" stroke-dasharray="3,3"/>
  <line x1="565" y1="320" x2="565" y2="340" stroke="#888" stroke-width="1" stroke-dasharray="3,3"/>
  <line x1="705" y1="320" x2="705" y2="340" stroke="#888" stroke-width="1" stroke-dasharray="3,3"/>

  <!-- 图例 -->
  <rect x="30" y="415" width="740" height="50" rx="5" fill="white" stroke="#DDD"/>
  <text x="50" y="435" font-size="10" font-weight="bold" fill="#333">图例：</text>
  <rect x="100" y="425" width="15" height="12" fill="#1F4E79"/><text x="120" y="436" font-size="9" fill="#333">主机区</text>
  <rect x="180" y="425" width="15" height="12" fill="#2E7D32"/><text x="200" y="436" font-size="9" fill="#333">开放平台区</text>
  <rect x="280" y="425" width="15" height="12" fill="#D9822B"/><text x="300" y="436" font-size="9" fill="#333">大数据区</text>
  <rect x="370" y="425" width="15" height="12" fill="#C62828"/><text x="390" y="436" font-size="9" fill="#333">DMZ区</text>
  <rect x="450" y="425" width="15" height="12" fill="#7B1FA2"/><text x="470" y="436" font-size="9" fill="#333">运维管理区</text>

  <text x="425" y="470" text-anchor="middle" font-size="10" fill="#888">数据来源：《金融数据中心网络架构与技术》第4-5章</text>
</svg>