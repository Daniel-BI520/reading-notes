<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 900 520" font-family="Arial, sans-serif">
  <defs>
    <linearGradient id="g1" x1="0%" y1="0%" x2="0%" y2="100%"><stop offset="0%" style="stop-color:#1F4E79"/><stop offset="100%" style="stop-color:#2C6FAC"/></linearGradient>
    <linearGradient id="g2" x1="0%" y1="0%" x2="0%" y2="100%"><stop offset="0%" style="stop-color:#5B8DB8"/><stop offset="100%" style="stop-color:#7AAAD0"/></linearGradient>
    <linearGradient id="g3" x1="0%" y1="0%" x2="0%" y2="100%"><stop offset="0%" style="stop-color:#D9822B"/><stop offset="100%" style="stop-color:#E8A050"/></linearGradient>
  </defs>
  <rect width="900" height="520" fill="#F8F9FA" rx="8"/>
  <text x="450" y="35" text-anchor="middle" font-size="18" font-weight="bold" fill="#1F4E79">图1 金融网络总体架构（三域模型）</text>

  <!-- 用户域 -->
  <rect x="30" y="60" width="250" height="420" rx="8" fill="#E8F0FE" stroke="#1F4E79" stroke-width="2"/>
  <rect x="30" y="60" width="250" height="40" rx="8" fill="url(#g1)"/>
  <text x="155" y="85" text-anchor="middle" font-size="15" font-weight="bold" fill="white">用户域</text>
  <rect x="50" y="115" width="210" height="35" rx="4" fill="#1F4E79" opacity="0.8"/>
  <text x="155" y="137" text-anchor="middle" font-size="11" fill="white">行内用户</text>
  <rect x="60" y="160" width="190" height="25" rx="3" fill="white" stroke="#5B8DB8"/>
  <text x="155" y="177" text-anchor="middle" font-size="10" fill="#333">分支机构用户</text>
  <rect x="60" y="192" width="190" height="25" rx="3" fill="white" stroke="#5B8DB8"/>
  <text x="155" y="209" text-anchor="middle" font-size="10" fill="#333">数据中心用户</text>
  <rect x="60" y="224" width="190" height="25" rx="3" fill="white" stroke="#5B8DB8"/>
  <text x="155" y="241" text-anchor="middle" font-size="10" fill="#333">总行用户</text>
  <rect x="50" y="265" width="210" height="35" rx="4" fill="#D9822B" opacity="0.8"/>
  <text x="155" y="287" text-anchor="middle" font-size="11" fill="white">行外用户</text>
  <rect x="60" y="310" width="190" height="25" rx="3" fill="white" stroke="#E8A050"/>
  <text x="155" y="327" text-anchor="middle" font-size="10" fill="#333">互联网用户</text>
  <rect x="60" y="342" width="190" height="25" rx="3" fill="white" stroke="#E8A050"/>
  <text x="155" y="359" text-anchor="middle" font-size="10" fill="#333">外联第三方用户</text>
  <!-- 接入区 -->
  <rect x="50" y="385" width="210" height="35" rx="4" fill="#A7B3C2" opacity="0.8"/>
  <text x="155" y="407" text-anchor="middle" font-size="11" fill="white">接入区</text>
  <rect x="60" y="425" width="90" height="22" rx="3" fill="white" stroke="#A7B3C2"/>
  <text x="105" y="440" text-anchor="middle" font-size="9" fill="#333">互联网接入</text>
  <rect x="160" y="425" width="90" height="22" rx="3" fill="white" stroke="#A7B3C2"/>
  <text x="205" y="440" text-anchor="middle" font-size="9" fill="#333">外联接入</text>

  <!-- 通道域 -->
  <rect x="320" y="60" width="260" height="420" rx="8" fill="#EBF5EB" stroke="#2E7D32" stroke-width="2"/>
  <rect x="320" y="60" width="260" height="40" rx="8" fill="#2E7D32"/>
  <text x="450" y="85" text-anchor="middle" font-size="15" font-weight="bold" fill="white">通道域</text>
  <text x="450" y="120" text-anchor="middle" font-size="13" font-weight="bold" fill="#2E7D32">内网通道</text>
  <rect x="345" y="135" width="210" height="30" rx="4" fill="#2E7D32" opacity="0.7"/>
  <text x="450" y="155" text-anchor="middle" font-size="11" fill="white">核心骨干网</text>
  <rect x="345" y="175" width="210" height="30" rx="4" fill="#2E7D32" opacity="0.6"/>
  <text x="450" y="195" text-anchor="middle" font-size="11" fill="white">一级骨干网</text>
  <rect x="345" y="215" width="210" height="30" rx="4" fill="#2E7D32" opacity="0.5"/>
  <text x="450" y="235" text-anchor="middle" font-size="11" fill="white">二级骨干网</text>
  <rect x="345" y="255" width="210" height="30" rx="4" fill="#2E7D32" opacity="0.4"/>
  <text x="450" y="275" text-anchor="middle" font-size="11" fill="white">网点广域网</text>
  <line x1="450" y1="165" x2="450" y2="175" stroke="#2E7D32" stroke-width="2"/>
  <line x1="450" y1="205" x2="450" y2="215" stroke="#2E7D32" stroke-width="2"/>
  <line x1="450" y1="245" x2="450" y2="255" stroke="#2E7D32" stroke-width="2"/>
  <text x="450" y="310" text-anchor="middle" font-size="13" font-weight="bold" fill="#2E7D32">互联网通道 / 外联网通道</text>
  <rect x="345" y="325" width="210" height="30" rx="4" fill="#2E7D32" opacity="0.3"/>
  <text x="450" y="345" text-anchor="middle" font-size="11" fill="#2E7D32">专线 / 互联网 / SD-WAN</text>

  <!-- 服务域 -->
  <rect x="620" y="60" width="250" height="420" rx="8" fill="#FFF3E0" stroke="#D9822B" stroke-width="2"/>
  <rect x="620" y="60" width="250" height="40" rx="8" fill="url(#g3)"/>
  <text x="745" y="85" text-anchor="middle" font-size="15" font-weight="bold" fill="white">服务域</text>
  <rect x="640" y="115" width="210" height="35" rx="4" fill="#D9822B" opacity="0.8"/>
  <text x="745" y="137" text-anchor="middle" font-size="11" fill="white">核心业务</text>
  <text x="745" y="160" text-anchor="middle" font-size="9" fill="#666">会计核算 | 客户信息 | 资金业务 | 结算</text>
  <rect x="640" y="175" width="210" height="35" rx="4" fill="#E8A050" opacity="0.7"/>
  <text x="745" y="197" text-anchor="middle" font-size="11" fill="white">中间业务</text>
  <text x="745" y="220" text-anchor="middle" font-size="9" fill="#666">银行卡 | 国际业务 | 代理 | 信贷</text>
  <rect x="640" y="235" width="210" height="35" rx="4" fill="#E8A050" opacity="0.6"/>
  <text x="745" y="257" text-anchor="middle" font-size="11" fill="#D9822B">渠道服务</text>
  <text x="745" y="280" text-anchor="middle" font-size="9" fill="#666">网银 | 手机银行 | 自助银行</text>
  <rect x="640" y="295" width="210" height="35" rx="4" fill="#E8A050" opacity="0.5"/>
  <text x="745" y="317" text-anchor="middle" font-size="11" fill="#D9822B">管理支撑</text>
  <text x="745" y="340" text-anchor="middle" font-size="9" fill="#666">经营管理 | 风险管理 | 办公系统</text>

  <!-- 连接线 -->
  <line x1="280" y1="200" x2="320" y2="200" stroke="#666" stroke-width="1.5" stroke-dasharray="5,3"/>
  <polygon points="315,195 325,200 315,205" fill="#666"/>
  <line x1="580" y1="200" x2="620" y2="200" stroke="#666" stroke-width="1.5" stroke-dasharray="5,3"/>
  <polygon points="615,195 625,200 615,205" fill="#666"/>

  <text x="450" y="500" text-anchor="middle" font-size="10" fill="#888">数据来源：《金融数据中心网络架构与技术》第1-2章</text>
</svg>