<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 900 440" font-family="Arial, sans-serif">
  <rect width="900" height="440" fill="#F8F9FA" rx="8"/>
  <text x="450" y="30" text-anchor="middle" font-size="18" font-weight="bold" fill="#1F4E79">图3 多地多中心总体架构</text>

  <!-- 城市A - 主中心 -->
  <rect x="50" y="55" width="280" height="320" rx="10" fill="#E8F0FE" stroke="#1F4E79" stroke-width="2" stroke-dasharray="8,3"/>
  <text x="190" y="80" text-anchor="middle" font-size="15" font-weight="bold" fill="#1F4E79">城市A - 主数据中心</text>
  <rect x="70" y="95" width="120" height="60" rx="5" fill="#1F4E79"/>
  <text x="130" y="118" text-anchor="middle" font-size="10" fill="white">核心业务区</text>
  <text x="130" y="135" text-anchor="middle" font-size="9" fill="#B0C4DE">主机区(大机)</text>
  <rect x="200" y="95" width="120" height="60" rx="5" fill="#2E7D32"/>
  <text x="260" y="118" text-anchor="middle" font-size="10" fill="white">开放平台区</text>
  <text x="260" y="135" text-anchor="middle" font-size="9" fill="#A5D6A7">x86服务器区</text>
  <rect x="70" y="165" width="120" height="60" rx="5" fill="#D9822B"/>
  <text x="130" y="188" text-anchor="middle" font-size="10" fill="white">DMZ区</text>
  <text x="130" y="205" text-anchor="middle" font-size="9" fill="#FFE0B2">互联网接入</text>
  <rect x="200" y="165" width="120" height="60" rx="5" fill="#5B8DB8"/>
  <text x="260" y="188" text-anchor="middle" font-size="10" fill="white">大数据区</text>
  <text x="260" y="205" text-anchor="middle" font-size="9" fill="#B0C4DE">数据分析平台</text>
  <rect x="70" y="235" width="250" height="50" rx="5" fill="#6B7280"/>
  <text x="195" y="257" text-anchor="middle" font-size="10" fill="white">Spine-Leaf Fabric (VXLAN+EVPN)</text>
  <text x="195" y="275" text-anchor="middle" font-size="9" fill="#D1D5DB">SDN控制器(iMaster NCE)</text>
  <rect x="70" y="295" width="250" height="35" rx="5" fill="#7B1FA2" opacity="0.8"/>
  <text x="195" y="317" text-anchor="middle" font-size="10" fill="white">互联网出口 | 专线出口</text>

  <!-- 城市A - 同城灾备 -->
  <rect x="370" y="55" width="180" height="320" rx="10" fill="#FFF3E0" stroke="#D9822B" stroke-width="2" stroke-dasharray="8,3"/>
  <text x="460" y="80" text-anchor="middle" font-size="14" font-weight="bold" fill="#D9822B">同城灾备中心</text>
  <rect x="385" y="95" width="150" height="50" rx="5" fill="#D9822B" opacity="0.7"/>
  <text x="460" y="118" text-anchor="middle" font-size="10" fill="white">灾备业务区</text>
  <text x="460" y="135" text-anchor="middle" font-size="9" fill="#FFE0B2">数据同步副本</text>
  <rect x="385" y="155" width="150" height="50" rx="5" fill="#2E7D32" opacity="0.7"/>
  <text x="460" y="178" text-anchor="middle" font-size="10" fill="white">Spine-Leaf Fabric</text>
  <text x="460" y="195" text-anchor="middle" font-size="9" fill="#A5D6A7">SDN控制器集群</text>
  <text x="460" y="250" text-anchor="middle" font-size="10" fill="#D9822B">RTO ≤ 30min</text>
  <text x="460" y="270" text-anchor="middle" font-size="10" fill="#D9822B">RPO ≈ 0</text>
  <rect x="385" y="290" width="150" height="45" rx="5" fill="#A7B3C2"/>
  <text x="460" y="317" text-anchor="middle" font-size="10" fill="white">DCI互联</text>

  <!-- 城市B - 异地灾备 -->
  <rect x="600" y="55" width="250" height="320" rx="10" fill="#EBF5EB" stroke="#2E7D32" stroke-width="2" stroke-dasharray="8,3"/>
  <text x="725" y="80" text-anchor="middle" font-size="14" font-weight="bold" fill="#2E7D32">异地灾备中心</text>
  <rect x="615" y="95" width="220" height="50" rx="5" fill="#2E7D32" opacity="0.7"/>
  <text x="725" y="118" text-anchor="middle" font-size="10" fill="white">异地灾备业务区</text>
  <text x="725" y="135" text-anchor="middle" font-size="9" fill="#A5D6A7">异步数据复制副本</text>
  <rect x="615" y="155" width="220" height="50" rx="5" fill="#5B8DB8" opacity="0.7"/>
  <text x="725" y="178" text-anchor="middle" font-size="10" fill="white">Spine-Leaf Fabric</text>
  <text x="725" y="195" text-anchor="middle" font-size="9" fill="#B0C4DE">SDN控制器(独立/集群拉远)</text>
  <text x="725" y="240" text-anchor="middle" font-size="10" fill="#2E7D32">RPO ≤ 15秒</text>
  <text x="725" y="260" text-anchor="middle" font-size="10" fill="#2E7D32">距离 ≥ 1000km</text>
  <rect x="615" y="290" width="220" height="45" rx="5" fill="#A7B3C2"/>
  <text x="725" y="317" text-anchor="middle" font-size="10" fill="white">DWDM / CPE互联</text>

  <!-- DCI连接线 -->
  <line x1="330" y1="310" x2="385" y2="310" stroke="#D9822B" stroke-width="3"/>
  <text x="357" y="340" text-anchor="middle" font-size="9" fill="#D9822B">DWDM</text>
  <text x="357" y="352" text-anchor="middle" font-size="9" fill="#D9822B">同城≤100km</text>
  <line x1="535" y1="310" x2="615" y2="310" stroke="#2E7D32" stroke-width="3"/>
  <text x="575" y="340" text-anchor="middle" font-size="9" fill="#2E7D32">DWDM/CPE</text>
  <text x="575" y="352" text-anchor="middle" font-size="9" fill="#2E7D32">异地≥1000km</text>

  <text x="450" y="400" text-anchor="middle" font-size="10" fill="#888">数据来源：《金融数据中心网络架构与技术》第3章</text>
</svg>