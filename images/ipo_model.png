<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 480" font-family="Arial, sans-serif">
  <rect width="800" height="480" fill="#F8F9FA" rx="8"/>
  <text x="400" y="35" text-anchor="middle" font-size="18" font-weight="bold" fill="#1F4E79">图2 IPO网络架构模型（四层模型）</text>

  <!-- S层 -->
  <rect x="80" y="60" width="640" height="85" rx="8" fill="#FFF3E0" stroke="#D9822B" stroke-width="2"/>
  <rect x="80" y="60" width="80" height="85" rx="8" fill="#D9822B"/>
  <text x="120" y="107" text-anchor="middle" font-size="28" font-weight="bold" fill="white">S层</text>
  <text x="200" y="85" font-size="14" font-weight="bold" fill="#D9822B">业务逻辑层（Service）</text>
  <text x="200" y="105" font-size="11" fill="#555">核心业务逻辑编排：交易路由、风控策略、业务规则引擎</text>
  <text x="200" y="125" font-size="11" fill="#555">面向业务场景的服务抽象，屏蔽底层网络复杂度</text>
  <text x="200" y="140" font-size="10" fill="#999">关键能力：业务编排 | 服务链(SFC) | 策略跟随</text>

  <!-- O层 -->
  <rect x="80" y="155" width="640" height="85" rx="8" fill="#E8F0FE" stroke="#1F4E79" stroke-width="2"/>
  <rect x="80" y="155" width="80" height="85" rx="8" fill="#1F4E79"/>
  <text x="120" y="202" text-anchor="middle" font-size="28" font-weight="bold" fill="white">O层</text>
  <text x="200" y="180" font-size="14" font-weight="bold" fill="#1F4E79">资源调度层（Orchestration）</text>
  <text x="200" y="200" font-size="11" fill="#555">SDN控制器 / 云管平台 / 自动化编排引擎</text>
  <text x="200" y="220" font-size="11" fill="#555">跨域资源统一调度，VM/BM上线自动化流程</text>
  <text x="200" y="235" font-size="10" fill="#999">关键能力：资源调度 | 自动化发放 | 云网协同 | 策略下发</text>

  <!-- P层 -->
  <rect x="80" y="250" width="640" height="85" rx="8" fill="#EBF5EB" stroke="#2E7D32" stroke-width="2"/>
  <rect x="80" y="250" width="80" height="85" rx="8" fill="#2E7D32"/>
  <text x="120" y="297" text-anchor="middle" font-size="28" font-weight="bold" fill="white">P层</text>
  <text x="200" y="275" font-size="14" font-weight="bold" fill="#2E7D32">资源池层（Pool）</text>
  <text x="200" y="295" font-size="11" fill="#555">Spine-Leaf Fabric网络资源池 | 安全资源池 | VAS资源池</text>
  <text x="200" y="315" font-size="11" fill="#555">网络功能虚拟化，逻辑分区（主机区/开放平台区/DMZ等）</text>
  <text x="200" y="330" font-size="10" fill="#999">关键能力：资源池化 | 逻辑隔离 | 弹性扩缩 | 设备无关</text>

  <!-- I层 -->
  <rect x="80" y="345" width="640" height="85" rx="8" fill="#F3E5F5" stroke="#7B1FA2" stroke-width="2"/>
  <rect x="80" y="345" width="80" height="85" rx="8" fill="#7B1FA2"/>
  <text x="120" y="392" text-anchor="middle" font-size="28" font-weight="bold" fill="white">I层</text>
  <text x="200" y="370" font-size="14" font-weight="bold" fill="#7B1FA2">基础设施层（Infrastructure）</text>
  <text x="200" y="390" font-size="11" fill="#555">物理交换机 / 路由器 / 防火墙 / 负载均衡 / DCI链路</text>
  <text x="200" y="410" font-size="11" fill="#555">物理硬件设备，多厂商设备（CloudEngine / HiSecEngine等）</text>
  <text x="200" y="425" font-size="10" fill="#999">关键能力：硬件冗余 | 链路聚合 | 高可用物理拓扑</text>

  <!-- 层间箭头 -->
  <polygon points="395,148 400,158 405,148" fill="#888"/>
  <polygon points="395,243 400,253 405,243" fill="#888"/>
  <polygon points="395,338 400,348 405,338" fill="#888"/>

  <text x="400" y="458" text-anchor="middle" font-size="10" fill="#888">数据来源：《金融数据中心网络架构与技术》第2章</text>
</svg>