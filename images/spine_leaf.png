<?xml version="1.0" encoding="UTF-8"?>
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 900 550" font-family="Arial, sans-serif">
  <rect width="900" height="550" fill="#F8F9FA" rx="8"/>
  <text x="450" y="30" text-anchor="middle" font-size="18" font-weight="bold" fill="#1F4E79">图4 Spine-Leaf Fabric架构（金融数据中心核心拓扑）</text>

  <!-- Spine层 -->
  <rect x="50" y="50" width="800" height="100" rx="8" fill="#E8F0FE" stroke="#1F4E79" stroke-width="1.5"/>
  <text x="75" y="70" font-size="13" font-weight="bold" fill="#1F4E79">Spine层（网络骨干）</text>
  <rect x="100" y="80" width="130" height="50" rx="5" fill="#1F4E79"/>
  <text x="165" y="108" text-anchor="middle" font-size="12" fill="white">Spine-1</text>
  <rect x="270" y="80" width="130" height="50" rx="5" fill="#1F4E79"/>
  <text x="335" y="108" text-anchor="middle" font-size="12" fill="white">Spine-2</text>
  <rect x="440" y="80" width="130" height="50" rx="5" fill="#1F4E79"/>
  <text x="505" y="108" text-anchor="middle" font-size="12" fill="white">Spine-3</text>
  <rect x="610" y="80" width="130" height="50" rx="5" fill="#1F4E79"/>
  <text x="675" y="108" text-anchor="middle" font-size="12" fill="white">Spine-N</text>

  <!-- 连接线（Spine到Leaf全互联，部分展示） -->
  <g stroke="#5B8DB8" stroke-width="1" opacity="0.5">
    <!-- Spine-1 到各Leaf -->
    <line x1="165" y1="130" x2="130" y2="195"/>
    <line x1="165" y1="130" x2="310" y2="195"/>
    <line x1="165" y1="130" x2="490" y2="195"/>
    <line x1="165" y1="130" x2="670" y2="195"/>
    <line x1="165" y1="130" x2="820" y2="195"/>
    <!-- Spine-2 -->
    <line x1="335" y1="130" x2="130" y2="195"/>
    <line x1="335" y1="130" x2="310" y2="195"/>
    <line x1="335" y1="130" x2="490" y2="195"/>
    <line x1="335" y1="130" x2="670" y2="195"/>
    <line x1="335" y1="130" x2="820" y2="195"/>
    <!-- Spine-3 -->
    <line x1="505" y1="130" x2="130" y2="195"/>
    <line x1="505" y1="130" x2="310" y2="195"/>
    <line x1="505" y1="130" x2="490" y2="195"/>
    <line x1="505" y1="130" x2="670" y2="195"/>
    <line x1="505" y1="130" x2="820" y2="195"/>
    <!-- Spine-N -->
    <line x1="675" y1="130" x2="130" y2="195"/>
    <line x1="675" y1="130" x2="310" y2="195"/>
    <line x1="675" y1="130" x2="490" y2="195"/>
    <line x1="675" y1="130" x2="670" y2="195"/>
    <line x1="675" y1="130" x2="820" y2="195"/>
  </g>

  <!-- Leaf层 -->
  <rect x="50" y="180" width="800" height="140" rx="8" fill="#EBF5EB" stroke="#2E7D32" stroke-width="1.5"/>
  <text x="75" y="200" font-size="13" font-weight="bold" fill="#2E7D32">Leaf层（接入层）</text>

  <!-- Server Leaf -->
  <rect x="80" y="210" width="100" height="50" rx="5" fill="#2E7D32"/>
  <text x="130" y="232" text-anchor="middle" font-size="10" fill="white">Server Leaf-1</text>
  <text x="130" y="248" text-anchor="middle" font-size="8" fill="#A5D6A7">M-LAG双活</text>
  <rect x="260" y="210" width="100" height="50" rx="5" fill="#2E7D32"/>
  <text x="310" y="232" text-anchor="middle" font-size="10" fill="white">Server Leaf-2</text>
  <text x="310" y="248" text-anchor="middle" font-size="8" fill="#A5D6A7">M-LAG双活</text>
  <!-- Service Leaf (VAS) -->
  <rect x="440" y="210" width="100" height="50" rx="5" fill="#D9822B"/>
  <text x="490" y="232" text-anchor="middle" font-size="10" fill="white">Service Leaf</text>
  <text x="490" y="248" text-anchor="middle" font-size="8" fill="#FFE0B2">FW/LB VAS</text>
  <!-- Border Leaf -->
  <rect x="620" y="210" width="100" height="50" rx="5" fill="#7B1FA2"/>
  <text x="670" y="232" text-anchor="middle" font-size="10" fill="white">Border Leaf</text>
  <text x="670" y="248" text-anchor="middle" font-size="8" fill="#D1C4E9">DCI互联</text>
  <rect x="770" y="210" width="65" height="50" rx="5" fill="#6B7280"/>
  <text x="802" y="232" text-anchor="middle" font-size="10" fill="white">Leaf-N</text>
  <text x="802" y="248" text-anchor="middle" font-size="8" fill="#D1D5DB">...</text>

  <!-- 服务器接入 -->
  <g fill="#333">
    <rect x="85" y="270" width="40" height="25" rx="3" fill="#A5D6A7" stroke="#2E7D32"/>
    <text x="105" y="286" text-anchor="middle" font-size="8" fill="#2E7D32">Server</text>
    <rect x="135" y="270" width="40" height="25" rx="3" fill="#A5D6A7" stroke="#2E7D32"/>
    <text x="155" y="286" text-anchor="middle" font-size="8" fill="#2E7D32">Server</text>
    <rect x="265" y="270" width="40" height="25" rx="3" fill="#A5D6A7" stroke="#2E7D32"/>
    <text x="285" y="286" text-anchor="middle" font-size="8" fill="#2E7D32">Server</text>
    <rect x="315" y="270" width="40" height="25" rx="3" fill="#A5D6A7" stroke="#2E7D32"/>
    <text x="335" y="286" text-anchor="middle" font-size="8" fill="#2E7D32">Server</text>
  </g>
  <rect x="445" y="270" width="90" height="25" rx="3" fill="#FFE0B2" stroke="#D9822B"/>
  <text x="490" y="286" text-anchor="middle" font-size="8" fill="#D9822B">Firewall / LB</text>

  <!-- Overlay层 -->
  <rect x="50" y="335" width="800" height="80" rx="8" fill="#FFF3E0" stroke="#D9822B" stroke-width="1.5"/>
  <text x="75" y="355" font-size="13" font-weight="bold" fill="#D9822B">Overlay层（VXLAN + EVPN）</text>
  <rect x="80" y="365" width="140" height="35" rx="4" fill="#D9822B" opacity="0.7"/>
  <text x="150" y="387" text-anchor="middle" font-size="10" fill="white">VXLAN隧道</text>
  <rect x="240" y="365" width="140" height="35" rx="4" fill="#D9822B" opacity="0.6"/>
  <text x="310" y="387" text-anchor="middle" font-size="10" fill="white">BGP EVPN控制面</text>
  <rect x="400" y="365" width="140" height="35" rx="4" fill="#D9822B" opacity="0.5"/>
  <text x="470" y="387" text-anchor="middle" font-size="10" fill="white">多租户隔离</text>
  <rect x="560" y="365" width="140" height="35" rx="4" fill="#D9822B" opacity="0.4"/>
  <text x="630" y="387" text-anchor="middle" font-size="10" fill="white">VM/BM自动化</text>
  <rect x="720" y="365" width="110" height="35" rx="4" fill="#D9822B" opacity="0.3"/>
  <text x="775" y="387" text-anchor="middle" font-size="10" fill="#D9822B">微分段</text>

  <!-- SDN控制器 -->
  <rect x="50" y="430" width="800" height="55" rx="8" fill="#F3E5F5" stroke="#7B1FA2" stroke-width="1.5"/>
  <text x="75" y="450" font-size="13" font-weight="bold" fill="#7B1FA2">SDN控制层</text>
  <rect x="130" y="455" width="160" height="20" rx="3" fill="#7B1FA2" opacity="0.7"/>
  <text x="210" y="469" text-anchor="middle" font-size="9" fill="white">iMaster NCE-Fabric</text>
  <rect x="310" y="455" width="120" height="20" rx="3" fill="#7B1FA2" opacity="0.6"/>
  <text x="370" y="469" text-anchor="middle" font-size="9" fill="white">云网协同</text>
  <rect x="450" y="455" width="120" height="20" rx="3" fill="#7B1FA2" opacity="0.5"/>
  <text x="510" y="469" text-anchor="middle" font-size="9" fill="white">AIOps智能运维</text>
  <rect x="590" y="455" width="120" height="20" rx="3" fill="#7B1FA2" opacity="0.4"/>
  <text x="650" y="469" text-anchor="middle" font-size="9" fill="#7B1FA2">业务链编排</text>

  <!-- Underlay/Overlay标注 -->
  <text x="870" y="155" text-anchor="end" font-size="9" fill="#1F4E79" transform="rotate(-90,870,155)">Underlay</text>
  <text x="870" y="370" text-anchor="end" font-size="9" fill="#D9822B" transform="rotate(-90,870,370)">Overlay</text>

  <text x="450" y="510" text-anchor="middle" font-size="10" fill="#888">数据来源：《金融数据中心网络架构与技术》第4-5章</text>
</svg>